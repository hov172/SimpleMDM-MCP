# ─── Required (direct mode) ───────────────────────────────────────────────────
# Your SimpleMDM API key. Use a read-only key unless you explicitly need writes.
SIMPLEMDM_API_KEY=your-api-key-here

# ─── Write actions (off by default) ──────────────────────────────────────────
# Set to true only when you need lock/sync/restart/assign/script actions.
# Use a key scoped to the minimum required permissions before enabling this.
# SIMPLEMDM_ALLOW_WRITES=true

# ─── MunkiReport enrichment (optional) ───────────────────────────────────────
# MUNKIREPORT_BASE_URL=https://munkireport.example.com
# MUNKIREPORT_MODULE_PREFIX=/module/simplemdm
# MUNKIREPORT_AUTH_HEADER_NAME=X-SIMPLEMDM-API-KEY
# MUNKIREPORT_AUTH_HEADER_VALUE=
# MUNKIREPORT_COOKIE=

# ─── Local app mode (optional, requires Report-SimpleMDM running) ─────────────
# Reads from the running Report-SimpleMDM app instead of the SimpleMDM API.
# Faster responses, automatic MunkiReport enrichment, no rate limit exposure.
# Enable in Report-SimpleMDM > Settings > Developer > Enable Local API first.
# LOCAL_APP_MODE=true
# LOCAL_APP_TOKEN=your-token-from-the-app
# LOCAL_APP_BASE_URL=http://127.0.0.1:49552
